# BruteScale Environment Variables
# Copy this file to .env and fill in your values

# Server port (default: 3000)
PORT=3000

# Node environment: development | production
NODE_ENV=production

# JWT secret — change this to a long random string in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Admin account — the user who registers with this email becomes an admin
ADMIN_EMAIL=admin@yourdomain.com
