# BruteScale — Environment Variables
# Copy this file to .env and fill in your values before starting the server.

# ── Server ────────────────────────────────────────────────────────────────────
# Port the server listens on
PORT=3000

# Node environment: production | development
NODE_ENV=production

# ── Security ──────────────────────────────────────────────────────────────────
# JWT signing secret — MUST be changed in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_64_CHARS_MIN

# ── Admin Account ─────────────────────────────────────────────────────────────
# Email address that has admin privileges.
# On first start the server auto-creates this account if it does not exist.
ADMIN_EMAIL=admin@yourdomain.com

# Password used when auto-creating the admin account.
# If the account already exists this value is ignored.
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
